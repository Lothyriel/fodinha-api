{
  "uid": "oh-hell-observability",
  "title": "Oh Hell Observability",
  "tags": ["oh-hell", "fly", "backend"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "label": "Datasource",
        "current": {
          "selected": true,
          "text": "default",
          "value": "default"
        }
      },
      {
        "name": "app",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "label": "App",
        "query": "label_values(http_server_request_count_total, app)",
        "definition": "label_values(http_server_request_count_total, app)",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "region",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "label": "Region",
        "query": "label_values(http_server_request_count_total{app=~\"$app\"}, region)",
        "definition": "label_values(http_server_request_count_total{app=~\"$app\"}, region)",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / s",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_request_count_total{app=~\"$app\",region=~\"$region\"}[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTTP Error %",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(http_server_request_count_total{app=~\"$app\",region=~\"$region\",http_response_status_code=~\"4..|5..\"}[5m])) / clamp_min(sum(rate(http_server_request_count_total{app=~\"$app\",region=~\"$region\"}[5m])), 0.0001)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "HTTP P95",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_bucket{app=~\"$app\",region=~\"$region\"}[5m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DB P95",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(db_client_operation_duration_bucket{app=~\"$app\",region=~\"$region\"}[5m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Requests / s by Route and Status",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (http_route, http_response_status_code) (rate(http_server_request_count_total{app=~\"$app\",region=~\"$region\"}[5m]))",
          "legendFormat": "{{http_route}} {{http_response_status_code}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP P95 Duration by Route",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_bucket{app=~\"$app\",region=~\"$region\"}[5m])))",
          "legendFormat": "{{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "DB Operations / s",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (db_collection_name, db_operation_name, success) (rate(db_client_operation_count_total{app=~\"$app\",region=~\"$region\"}[5m]))",
          "legendFormat": "{{db_collection_name}} {{db_operation_name}} success={{success}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DB P95 Duration by Operation",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, db_collection_name, db_operation_name) (rate(db_client_operation_duration_bucket{app=~\"$app\",region=~\"$region\"}[5m])))",
          "legendFormat": "{{db_collection_name}} {{db_operation_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Actor Starts / s",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (actor_startup_kind, success) (rate(actor_startup_count_total{app=~\"$app\",region=~\"$region\"}[5m]))",
          "legendFormat": "{{actor_startup_kind}} success={{success}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Actor Message Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (actor_message) (rate(actor_message_count_total{app=~\"$app\",region=~\"$region\"}[5m]))",
          "legendFormat": "{{actor_message}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Actor Message P95 Duration",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, actor_message) (rate(actor_message_duration_bucket{app=~\"$app\",region=~\"$region\"}[5m])))",
          "legendFormat": "{{actor_message}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Actor Startup P95 Duration",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, actor_startup_kind) (rate(actor_startup_duration_bucket{app=~\"$app\",region=~\"$region\"}[5m])))",
          "legendFormat": "{{actor_startup_kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
